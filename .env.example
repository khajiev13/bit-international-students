BIT_PROF_LLM_API_KEY=your-llm-api-key
BIT_PROF_LLM_BASE_URL=https://api.silra.cn/v1/
BIT_PROF_LLM_MODEL=deepseek-v4-flash

# Public port used by docker-compose.yml for local host access.
PUBLIC_PORT=8081

# Frontend build-time API prefix. Keep /api when serving through Caddy.
VITE_API_BASE_URL=/api

# Optional Cloudflare Tunnel deployment.
CLOUDFLARE_TUNNEL_TOKEN=your-cloudflare-tunnel-token

# Optional API/server controls.
LAB4_ALLOWED_ORIGINS=http://localhost:8081,http://127.0.0.1:8081
LAB4_ALLOWED_HOSTS=localhost,127.0.0.1,lab4_professor_caddy
LAB4_MAX_PROMPT_CHARS=2000
LAB4_AGENT_RECURSION_LIMIT=80

# Optional LangSmith Context Hub route mounted at /wiki when configured.
LAB4_CONTEXT_HUB_ENABLED=false
LAB4_CONTEXT_HUB_IDENTIFIER=-/bit-professor-agent
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=your-langsmith-api-key
LANGSMITH_PROJECT=bit_agent_app
LAB4_DEPLOYMENT_ENV=production

# Optional admin endpoint credentials for reading the question/answer log.
LAB4_ADMIN_USERNAME=admin
LAB4_ADMIN_PASSWORD=replace-with-a-strong-password
